# FinMind local environment sample.
# Copy to `.env` for Docker Compose:
# cp .env.sample .env

# Admin login
FINMIND_ADMIN_USERNAME=admin
FINMIND_ADMIN_PASSWORD=admin
FINMIND_SESSION_SECRET=session-secret-with-length

# PostgreSQL / TimescaleDB container
POSTGRES_DB=finmind
POSTGRES_USER=finmind
POSTGRES_PASSWORD=finmind

# API database URL inside Docker Compose network.
# For a host-run API, use: postgresql://finmind:finmind@127.0.0.1:5432/finmind
FINMIND_DATABASE_URL=postgresql://finmind:finmind@db:5432/finmind

# Provider selection
# mock: deterministic local source data
# Real free providers: vnstock, yfinance, stooq daily CSV, sjc_official
FINMIND_VN_PROVIDER=vnstock
# US recent 1h uses yfinance; US daily base uses no-key Stooq daily CSV.
FINMIND_US_PROVIDER=yfinance
FINMIND_XAUUSD_PROVIDER=yfinance
FINMIND_XAUUSD_DAILY_FALLBACK=alpha_vantage
FINMIND_SJC_PROVIDER=sjc_official

# Optional provider credentials.
FINMIND_VNSTOCK_API_KEY=replace-with-vnstock-key
FINMIND_ALPHA_VANTAGE_API_KEY=replace-with-alpha-vantage-key
FINMIND_PROVIDER_TIMEOUT_SECONDS=15

# V1 is VN-only. Leave FINMIND_ROADMAP_MARKETS=false to keep US, XAUUSD,
# and SJC operator presets dormant; set to true to re-enable the roadmap
# market-history, market-latest, us-daily-history, and us-xauusd-history
# presets while their connectors stay opt-in.
FINMIND_ROADMAP_MARKETS=false

# Backfill runner defaults. vn-history (default) drives vn_prices_daily
# (required) and vn_prices 1h (best-effort, clamped to a rolling 60d
# window). Roadmap presets (market-latest, market-history,
# us-daily-history, us-xauusd-history) only run when
# FINMIND_ROADMAP_MARKETS=true.
FINMIND_BACKFILL_PRESET=vn-history
FINMIND_BACKFILL_FROM_DATE=2026-06-18
FINMIND_BACKFILL_TO_DATE=2026-06-25

# UI -> API proxy inside Docker Compose.
VITE_API_PROXY_TARGET=http://api:8000
