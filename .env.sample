# FinMind authentication
FINMIND_ADMIN_USERNAME=admin
FINMIND_ADMIN_PASSWORD=change-me
FINMIND_SESSION_SECRET=replace-with-at-least-16-characters

# VN stock and Gold data providers
FINMIND_VNSTOCK_API_KEY=
FINMIND_DATAFLOW_PROVIDER_TIMEOUT_SECONDS=15
FINMIND_GOLD_DATA_PROVIDER=twelvedata
FINMIND_TWELVE_DATA_API_KEY=your-twelve-data-api-key

# Persistence
FINMIND_DATABASE_URL=postgresql://finmind:finmind@localhost:5432/finmind

# UI development proxy
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# LLM runtime
# Use the gemini/ prefix for Google AI Studio through LiteLLM.
LITELLM_CHAT_MODEL=gemini/gemini-2.5-flash
LITELLM_API_KEY=your-google-ai-studio-api-key
GEMINI_API_KEY=your-google-ai-studio-api-key
# Leave LITELLM_API_BASE unset for native Gemini API access.
# LITELLM_API_BASE=

# Streaming limits
FINMIND_STREAM_GLOBAL_LIMIT=32
FINMIND_STREAM_PER_USER_LIMIT=4
FINMIND_SYNC_OFFLOAD_LIMIT=8
FINMIND_STREAM_HEARTBEAT_SECONDS=5
